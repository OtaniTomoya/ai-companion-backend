# このファイルを .env にコピーし、実際のシークレットを入力してください。
# .env はコミットしないでください。

OPENAI_API_KEY=
AIAVATAR_API_KEY=

APP_TIMEZONE=Asia/Tokyo
AIAVATAR_DEBUG=false

# 公開MVPで固定しているPipeline:
# STT: OpenAI
# LLM: OpenAI ChatGPT service
# TTS: VOICEVOX / AivisSpeech互換のローカルエンドポイント
OPENAI_LLM_MODEL=gpt-5-nano
OPENAI_LLM_REASONING_EFFORT=minimal
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE=ja

AIAVATAR_VAD_MODE=auto
AIAVATAR_VAD_SILENCE_SECONDS=0.5
AIAVATAR_VAD_SEGMENT_SILENCE_SECONDS=0.05
AIAVATAR_VAD_MAX_SECONDS=10.0
AIAVATAR_VAD_MIN_SECONDS=0.2

VOICEVOX_BASE_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=8

AIAVATAR_MERGE_REQUEST_THRESHOLD=3.0
AIAVATAR_INVOKE_TIMEOUT_SECONDS=60.0
AIAVATAR_RESPONSE_AUDIO_CHUNK_SIZE=0
AIAVATAR_TTS_CACHE_DIR=.cache/tts
CAMERA_CONTEXT_TTL_SECONDS=4.0
